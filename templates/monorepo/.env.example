# Copie pra .env.local (dev) e .env.production (prod). NUNCA commite os valores reais.
# Toda env var nova: declarada AQUI + validada em apps/api/src/config/env.ts (Zod)
# + neutralizada em apps/api/vitest.config.ts (se for credencial de provedor).

# App
NODE_ENV=development
API_PORT=3001
WEB_ORIGIN=http://localhost:3000
API_URL=http://localhost:3001

# Fissão (dev): 1 = hooks servem fixtures do contrato quando a API não subiu.
# SÓ funciona em development — nunca ligue em produção (lib/api/fixtures.ts).
NEXT_PUBLIC_USE_FIXTURES=

# Banco — local via docker compose (docker-compose.dev.yml) ou Supabase managed
# local:    postgres://postgres:postgres@localhost:5432/app_dev
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth
AUTH_SECRET=

# IA
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Email (adapter: vazio = modo dev, loga no console)
RESEND_API_KEY=
