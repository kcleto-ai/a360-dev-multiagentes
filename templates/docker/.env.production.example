# Copie pra .env.production NO SERVIDOR e preencha. NUNCA commite o .env.production.
NODE_ENV=production

# IA
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Banco (Supabase)
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth
AUTH_SECRET=

# URLs públicas (use o domínio real — entra no CORS whitelist e no front)
PUBLIC_WEB_URL=https://seu-dominio.com
PUBLIC_API_URL=https://seu-dominio.com/api
